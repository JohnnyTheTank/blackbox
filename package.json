{
  "name": "blackbox",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal CLI coding agent using OpenRouter tool calling",
  "type": "module",
  "bin": {
    "blackbox": "bin/blackbox.mjs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "link": "npm link",
    "unlink": "npm unlink -g blackbox",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@openrouter/agent": "0.4.0",
    "@openrouter/sdk": "0.12.19",
    "zod": "4.3.6"
  }
}
